# --- Server ---
PORT=3000
NODE_ENV=development

# --- Database ---
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=your_db_name

# --- JWT ---
JWT_SECRET=your_super_long_random_jwt_secret_here
